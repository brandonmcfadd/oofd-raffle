  <meta name="msapplication-TileImage" content="/ms-icon-144x144.png">
  <meta name="theme-color" content="#ffffff">
  <meta charset="UTF-8">
  <title>Raffle Numbers</title>
  <style>
    .header-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      text-align: left;
      margin-bottom: 1rem;
    }

    .header-text {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .header-text h1,
    .header-text h2,
    .header-text h3 {
      margin: 0.25rem 0;
    }

    .header-row .logo {
      height: 8rem;
      width: auto;
    }

    .logo-container {
      position: absolute;
      top: 1rem;
      right: 1rem;
    }

    .thank-you-container {
      position: fixed;
      bottom: 0.25rem;
      left: 0;
      width: 100%;
      text-align: center;
      color: white;
      font-size: 1rem;
    }

    .mini-text {
      position: fixed;
      text-align: right;
      color: white;
      font-size: 0.75rem;
      bottom: 0.5rem;
      right: 1rem;
      z-index: 1000;
      /* keeps it above other content */
    }

    a,
    a:hover,
    a:active,
    a:visited {
      color: white;
    }

    .logo {
      height: 8rem;
      padding: 0.5rem;
      width: auto;
    }

    h1 {
      color: white;
      font-size: 3rem;
      margin: 0.25rem 0;
      margin: 0.25rem 0;
      text-align: center;
    }

    h2 {
      color: white;
      font-size: 1.5rem;
      text-align: center;
      margin: 0.5rem 0;
    }

    h3 {
      color: white;
      font-size: 1.15rem;
      margin: 0.5rem 0;
      margin-bottom: 1rem;
      text-align: center;
    }

    body {
      font-family: sans-serif;
      text-align: center;
      padding: 2rem;
      padding-bottom: 4rem;
      background: black;
    }

    .main-number-row {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 0.5rem;
    }

    .main-number-container {
      background: white;
      padding: 1rem 1rem;
      border-radius: 5px;

      display: flex;
      flex-direction: column;
      justify-content: center;

      width: 550px;
      min-height: 100px;

      text-align: center;
      box-sizing: border-box;
    }

    .main-number {
      font-size: 1.6rem;
      font-weight: bold;
      color: #d32f2f;
      margin-top: 0.25rem;
      margin-bottom: 0.25rem;
      min-width: 300px;
    }

    .main-prize {
      font-size: 1.5rem;
      color: black;
      margin-bottom: 0.25rem;
    }

    .main-prize-donor {
      font-size: 1.35rem;
      color: black;
      margin-bottom: 0.25rem;
    }

    .other-numbers {
      display: flex;
      flex-wrap: wrap;
      /* Allow items to wrap into new rows */
      justify-content: center;
      gap: 0.5rem;
      color: black;
    }

    .other-number {
      background: white;
      padding: 0.75rem;
      border-radius: 10px;
      min-width: 250px;
      max-width: 250px;

      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;

      text-align: center;
    }

    .other-number-number {
      font-size: 1.25rem;
      font-weight: bold;
    }

    .other-number-prize {
      font-size: 1.25rem;
      color: #444;
    }

    .other-number-donor {
      font-size: 1rem;
      color: #444;
    }

    .qr-code-container {
      display: none;
      /* hidden by default, shown only on desktop */
    }

    .main-number,
    .main-prize,
    .main-prize-donor {
      word-break: break-word;
      overflow-wrap: anywhere;
      white-space: normal;
    }

    .other-number-number,
    .other-number-prize,
    .other-number-donor {
      width: 100%;
      text-align: center;
    }

    .goal-meter {
      position: fixed;
      bottom: 1rem;
      right: 1rem;
      z-index: 1000;
      /* keeps it above other content */
    }

    /* Base styles (desktop/tablet) already mostly set correctly */

    /* Responsive tweaks for mobile */
    @media (max-width: 1100px) {
      body {
        padding: 1rem;
        padding-bottom: 4rem;
      }

      h1 {
        font-size: 3rem;
      }

      h2 {
        font-size: 2.25rem;
      }

      h3 {
        font-size: 2rem;
      }

      .logo-container {
        position: relative;
        top: unset;
        right: unset;
        transform: none;
        text-align: center;
        margin-bottom: 1rem;
      }

      .logo {
        height: 10rem;
      }

      .main-number-container {
        width: 100%;
        max-width: 90%;
        margin: 1rem auto;
      }

      .other-numbers {
        flex-direction: column;
        align-items: center;
      }

      .other-number {
        width: 100%;
        max-width: 90%;
        min-width: unset;
        font-size: 1.25rem;
        margin: 0.5rem;
      }

      .header-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
      }

      .header-text {
        text-align: center;
      }

      .header-row .logo {
        height: 8rem;
        padding: 0;
      }

      .qr-code-left {
        display: none;
      }

      .qr-code-right {
        display: none;
      }

      .goal-meter {
        display: none;
      }
    }

    @media (min-width: 1101px) {
      .qr-code-left {
        position: fixed;
        top: 1rem;
        left: 1rem;
        display: block;
        z-index: 1000;
        color: white;
        font-size: 1.15rem;
      }

      .qr-code-right {
        position: fixed;
        top: 1rem;
        right: 1rem;
        display: block;
        z-index: 1000;
        color: white;
        font-size: 1.15rem;
        text-align: center;
      }

      .qr-block {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .qr-code {
        width: 150px;
        height: auto;
        opacity: 0.9;
      }

      .other-numbers.spaced {
        padding-top: 3.5rem;
      }
    }

    .hidden {
      display: none;
      visibility: hidden;
    }
  </style>

</head>

<body>
  <div class="header-row">
    <img src="/logo.png" alt="Logo" class="logo">

    <div class="header-text">
      <h1>Hootenanny Raffle Numbers</h1>
      <h2>Prizes can be claimed at the prize table!</h2>
      <h3>Winners must be present to collect their prize, and prizes must be collected by 9pm!</h3>
    </div>
  </div>

  <div class="main-number-row">
    <div id="main-number-container" class="main-number-container">
      <div id="main-number" class="main-number"></div>
      <div id="main-prize" class="main-prize"></div>
      <div id="main-prize-donor" class="main-prize-donor"></div>
      <div id="main-prize-value" class="main-prize-donor"></div>
    </div>

    <div id="main-number-container-2" class="main-number-container">
      <div id="main-number-2" class="main-number"></div>
      <div id="main-prize-2" class="main-prize"></div>
      <div id="main-prize-donor-2" class="main-prize-donor"></div>
      <div id="main-prize-value-2" class="main-prize-donor"></div>
    </div>
  </div>

  <div id="other-numbers" class="other-numbers">
    <!-- JS will populate this -->
  </div>

  <div class="qr-code-left">
    <div class="qr-block">
      <img src="/raffle-check-qr.svg" alt="Check Ticket QR" class="qr-code">
      <p>Scan above or visit<br>hootenanny.oofd.org<br>to check your ticket!</p>
    </div>
  </div>

  <div class="qr-code-right">
    <div class="qr-block">
      <img src="/direct-ask-qr.svg" alt="Donate QR" class="qr-code">
      <p>Scan above to donate!</p>
    </div>
  </div>

  <div class="thank-you-container">
    <p>Built for <a href="https://oofd.org" target="_blank">Out Our Front Door</a> with 💙 by <a
        href="https://github.com/brandonmcfadd/oofd-raffle" target="_blank">Brandon
        McFadden</a></p>
  </div>
  <div class="mini-text">
    <p class="mini-text">Version 0.2.73</p>
  </div>
  <script>
    async function fetchRaffleNumbers() {
      try {
        const response = await fetch('/api/current_numbers');
        const bingo_winner = await fetch('/api/current_numbers/bingo')
        const data = (await response.json()).slice();
        const bingo_winner_data = (await bingo_winner.json());

        const mainNumberDiv = document.getElementById('main-number-container');
        const mainNumberDiv2 = document.getElementById('main-number-container-2');
        const otherContainer = document.getElementById('other-numbers');
        const mainNumberEl = document.getElementById('main-number');
        const mainPrizeEl = document.getElementById('main-prize');
        const mainPrizeEl2 = document.getElementById('main-prize-donor');
        const value1 = document.getElementById('main-prize-value');

        if (Array.isArray(data) && data.length > 0) {
          otherContainer.innerHTML = '';

          // Find grand prizes (1 & 2)
          const grandPrizes = [1, 2]
            .map(num => data.find(entry => entry.prize_number == num))
            .filter(Boolean);

          const otherPrizes = data
            .filter(entry => entry.prize_number != 1 && entry.prize_number != 2)
            .sort((a, b) => Number(a.prize_number) - Number(b.prize_number));

          if (grandPrizes.length > 0) {
            // Show main container
            mainNumberDiv.classList.remove('hidden');
            mainNumberDiv2.classList.remove('hidden');
            otherContainer.classList.remove('spaced');

            const prize1 = data.find(entry => entry.prize_number == 1);
            const prize2 = data.find(entry => entry.prize_number == 2);

            // ===== PRIZE 1 =====
            const container1 = document.getElementById('main-number-container');
            const number1 = document.getElementById('main-number');
            const prize1El = document.getElementById('main-prize');
            const donor1 = document.getElementById('main-prize-donor');

            if (prize1) {
              container1.classList.remove('hidden');

              number1.innerHTML = `Ticket #${prize1.number}<br>Grand Prize #1`;
              prize1El.innerHTML = prize1.prize;
              donor1.innerHTML = `<b>Donor:</b> <i>${prize1.donor}</i>`;
              value1.innerHTML = `<b>Value:</b> <i>$${prize1.value}</i>`;
            } else {
              container1.classList.add('hidden');
              value1.classList.add('hidden');
            }

            // ===== PRIZE 2 =====
            const container2 = document.getElementById('main-number-container-2');
            const number2 = document.getElementById('main-number-2');
            const prize2El = document.getElementById('main-prize-2');
            const donor2 = document.getElementById('main-prize-donor-2');
            const value2 = document.getElementById('main-prize-value-2');

            if (prize2) {
              container2.classList.remove('hidden');

              number2.innerHTML = `Ticket #${prize2.number}<br>Grand Prize #2`;
              prize2El.innerHTML = prize2.prize;
              donor2.innerHTML = `<b>Donor:</b> <i>${prize2.donor}</i>`;
              value2.innerHTML = `<b>Value:</b> <i>$${prize2.value}</i>`;
            } else {
              container2.classList.add('hidden');
            }
          } else {
            // Hide main container if no grand prizes drawn yet
            mainNumberDiv.classList.add('hidden');
            mainNumberDiv2.classList.add('hidden');
            otherContainer.classList.add('spaced');
          }

          // Render all other prizes
          otherPrizes.forEach(entry => {
            if (entry.prize_number == 22) {
              winning_entry_number = "Winner: " + (bingo_winner_data[bingo_winner_data.length - 1].name)
            } else {
              winning_entry_number = "Ticket #" + (entry.number)
            }
            const div = document.createElement('div');
            div.className = 'other-number';
            div.innerHTML = `
      <div class="other-number-number">${winning_entry_number}<br>Prize #${entry.prize_number}</div>
      <div class="other-number-prize">${entry.prize}</div>
      <div class="other-number-donor"><b>Donor:</b> <i>${entry.donor}</i></div>
      <div class="other-number-donor"><b>Value:</b> <i>$${entry.value}</i></div>
    `;
            otherContainer.appendChild(div);
          });

        } else {
          // Only reset if not already in "Waiting..." state
          mainNumberDiv.classList.remove("hidden")
          mainNumberDiv2.classList.add('hidden');
          value1.classList.add('hidden');
          if (mainNumberEl.textContent !== "Waiting...") {
            mainNumberEl.textContent = "Waiting...";
            mainPrizeEl.textContent = "Drum Roll Please 🥁🙏";
            mainPrizeEl2.innerHTML = `<img src="/logo-tent.png" alt="Tent Logo" style="max-width: 250px; height: auto; margin-top: 1rem;">`;
            otherContainer.innerHTML = '';
          }
        }
      } catch (error) {
        console.error('Error fetching raffle numbers:', error);
      }
    }

    // Fetch every second
    setInterval(fetchRaffleNumbers, 1000);
    fetchRaffleNumbers();
  </script>



</body>

</html>